{
    "swagger": "2.0",
    "info": {
        "description": "Vesalius-m Backend API Docs (IHP-UAT Version).",
        "title": "(IHP-UAT) Vesalius-m Backend API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/ih/mobile_central_2_0_0",
    "paths": {
        "/common/country/list": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Common"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.Country"
                            }
                        }
                    }
                }
            }
        },
        "/common/nationality/list": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Common"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.Nationality"
                            }
                        }
                    }
                }
            }
        },
        "/common/telcode/list": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Common"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.CountryTelCode"
                            }
                        }
                    }
                }
            }
        },
        "/login": {
            "post": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "parameters": [
                    {
                        "description": "Login Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.LoginDto"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.LoginDto": {
            "type": "object",
            "required": [
                "password",
                "username"
            ],
            "properties": {
                "fromAdmin": {
                    "type": "boolean",
                    "default": false
                },
                "fromBiometric": {
                    "type": "integer",
                    "default": 0
                },
                "machineId": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "playerId": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "model.Country": {
            "type": "object",
            "properties": {
                "countryCode": {
                    "type": "string"
                },
                "countryName": {
                    "type": "string"
                },
                "telCode": {
                    "type": "string"
                }
            }
        },
        "model.CountryTelCode": {
            "type": "object",
            "properties": {
                "countryName": {
                    "type": "string"
                },
                "telCode": {
                    "type": "string"
                }
            }
        },
        "model.Nationality": {
            "type": "object",
            "properties": {
                "nationality": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Type \"Bearer\" followed by a space and JWT token.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}